# Maven build output
target/
!**/src/main/**/target/
!**/src/test/**/target/

# Compiled class files
*.class

# Log files
*.log

# Package files
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/
.idea_modules/

# Eclipse
.classpath
.project
.settings/
bin/

# VS Code
.vscode/

# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ML model files — supplied at runtime, never committed
*.onnx
vocab.txt

# Environment / secrets — never commit these
.env
.env.*
*.local
application-local.yml
application-local.yaml

# Dependency reduced POM (created by maven-shade-plugin)
dependency-reduced-pom.xml

# JVM crash logs
hs_err_pid*
replay_pid*
